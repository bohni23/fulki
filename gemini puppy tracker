import React, { useState, useEffect } from "react";
import { 
  StyleSheet, 
  Text, 
  View, 
  ScrollView, 
  TouchableOpacity, 
  Modal, 
  TextInput,
  SafeAreaView,
  Platform
} from "react-native";
import AsyncStorage from "@react-native-async-storage/async-storage";

// ─── Constants ────────────────────────────────────────────────────
const FONT = Platform.OS === "ios" ? "Cochin" : "sans-serif";

const CATS = [
  { id:"water",   emoji:"💧", label:"Water",   color:"#3A9BD5", bg:"#E3F2FD", border:"#B3D9F5" },
  { id:"food",    emoji:"🍗", label:"Food",    color:"#C87F1A", bg:"#FEF3DC", border:"#F5DAA0" },
  { id:"nap",     emoji:"💤", label:"Nap",     color:"#7A68B0", bg:"#EEE9F8", border:"#CFC8EE" },
  { id:"pee",     emoji:"🌱", label:"Pee",     color:"#3D8F3D", bg:"#E8F5E8", border:"#A8D8A8" },
  { id:"poop",    emoji:"💩", label:"Poop",    color:"#7A4F2C", bg:"#F5EDE3", border:"#DDCAB8" },
  { id:"zoomies", emoji:"🏎️", label:"Zoomies", color:"#C02828", bg:"#FEE8E8", border:"#F5B0B0" },
];

const uid = () => Date.now().toString(36) + Math.random().toString(36).slice(2,6);
const fmt = iso => new Date(iso).toLocaleTimeString([],{hour:"2-digit",minute:"2-digit"});

export default function App() {
  const [entries, setEntries] = useState([]);
  const [editingEntry, setEditingEntry] = useState(null);
  const [editHours, setEditHours] = useState("");
  const [editMinutes, setEditMinutes] = useState("");

  // Load Data
  useEffect(() => {
    async function loadData() {
      try {
        const stored = await AsyncStorage.getItem("pup-entries");
        if (stored) setEntries(JSON.parse(stored));
      } catch (_) {}
    }
    loadData();
  }, []);

  const saveEntries = async (nextEntries) => {
    setEntries(nextEntries);
    try {
      await AsyncStorage.setItem("pup-entries", JSON.stringify(nextEntries));
    } catch (_) {}
  };

  const handleLog = (id) => {
    const now = new Date().toISOString();
    saveEntries([{ id: uid(), type: id, time: now }, ...entries]);
  };

  const openEdit = (entry) => {
    setEditingEntry(entry);
    const d = new Date(entry.time);
    setEditHours(String(d.getHours()).padStart(2, "0"));
    setEditMinutes(String(d.getMinutes()).padStart(2, "0"));
  };

  const saveEdit = () => {
    const updatedEntries = entries.map(e => {
      if (e.id === editingEntry.id) {
        const d = new Date(e.time);
        d.setHours(parseInt(editHours, 10), parseInt(editMinutes, 10));
        return { ...e, time: d.toISOString() };
      }
      return e;
    });
    saveEntries(updatedEntries);
    setEditingEntry(null);
  };

  const deleteEntry = (id) => {
    saveEntries(entries.filter(e => e.id !== id));
    setEditingEntry(null);
  };

  return (
    <SafeAreaView style={styles.container}>
      <View style={styles.header}>
        <Text style={styles.headerTitle}>🐾 Puppy's Log</Text>
      </View>

      <ScrollView style={styles.content}>
        <Text style={styles.sectionTitle}>QUICK LOG ACTIONS</Text>
        <View style={styles.grid}>
          {CATS.map(c => (
            <TouchableOpacity 
              key={c.id} 
              style={[styles.card, { backgroundColor: c.bg, borderColor: c.border }]} 
              onPress={() => handleLog(c.id)}
            >
              <Text style={styles.cardEmoji}>{c.emoji}</Text>
              <Text style={[styles.cardLabel, { color: c.color }]}>{c.label}</Text>
            </TouchableOpacity>
          ))}
        </View>

        <Text style={styles.sectionTitle}>ACTIVITY LOG (TAP TO EDIT/DELETE)</Text>
        <View style={styles.logList}>
          {entries.length === 0 ? (
            <Text style={styles.emptyText}>No activities logged yet.</Text>
          ) : (
            entries.map(e => {
              const cat = CATS.find(c => c.id === e.type);
              return (
                <TouchableOpacity key={e.id} style={styles.logItem} onPress={() => openEdit(e)}>
                  <Text style={styles.logText}>{cat?.emoji} {cat?.label}</Text>
                  <Text style={styles.logTime}>{fmt(e.time)} ✏️</Text>
                </TouchableOpacity>
              );
            })
          )}
        </View>
      </ScrollView>

      {/* Edit / Delete Modal */}
      <Modal visible={editingEntry !== null} transparent animationType="fade">
        <View style={styles.modalOverlay}>
          <View style={styles.modalContent}>
            <Text style={styles.modalTitle}>Edit Log Time</Text>
            
            <View style={styles.timeInputRow}>
              <TextInput 
                style={styles.timeInput} 
                keyboardType="number-pad" 
                maxLength={2} 
                value={editHours} 
                onChangeText={setEditHours}
              />
              <Text style={styles.timeColon}>:</Text>
              <TextInput 
                style={styles.timeInput} 
                keyboardType="number-pad" 
                maxLength={2} 
                value={editMinutes} 
                onChangeText={setEditMinutes}
              />
            </View>

            <TouchableOpacity style={[styles.btn, styles.btnSave]} onPress={saveEdit}>
              <Text style={styles.btnText}>Save Changes</Text>
            </TouchableOpacity>
            
            <TouchableOpacity style={[styles.btn, styles.btnDelete]} onPress={() => deleteEntry(editingEntry?.id)}>
              <Text style={styles.btnText}>Delete Entry Permanently</Text>
            </TouchableOpacity>

            <TouchableOpacity style={[styles.btn, styles.btnCancel]} onPress={() => setEditingEntry(null)}>
              <Text style={[styles.btnText, { color: "#7B5030" }]}>Cancel</Text>
            </TouchableOpacity>
          </View>
        </View>
      </Modal>
    </SafeAreaView>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: "#FDF6EC", paddingTop: Platform.OS === "android" ? 40 : 0 },
  header: { backgroundColor: "#C87820", padding: 20, alignItems: "center" },
  headerTitle: { color: "#fff", fontSize: 22, fontWeight: "bold", fontFamily: FONT },
  content: { padding: 20 },
  sectionTitle: { fontSize: 11, fontWeight: "bold", color: "#B08050", marginBottom: 10, letterSpacing: 1, fontFamily: FONT },
  grid: { flexDirection: "row", flexWrap: "wrap", justifyContent: "space-between", marginBottom: 25 },
  card: { width: "31%", borderRadius: 16, padding: 12, alignItems: "center", marginBottom: 10, borderWidth: 1.5 },
  cardEmoji: { fontSize: 24, marginBottom: 4 },
  cardLabel: { fontSize: 12, fontWeight: "bold", fontFamily: FONT },
  logList: { backgroundColor: "#fff", borderRadius: 12, borderWidth: 1, borderColor: "#EDD5A8", padding: 8, marginBottom: 40 },
  logItem: { flexDirection: "row", justifyContent: "space-between", padding: 14, borderBottomWidth: 1, borderBottomColor: "#F5EDE3" },
  logText: { fontSize: 16, fontWeight: "600", color: "#4A2E10", fontFamily: FONT },
  logTime: { fontSize: 14, color: "#A08060", fontFamily: FONT },
  emptyText: { padding: 20, textAlign: "center", color: "#A08060", fontStyle: "italic", fontFamily: FONT },
  modalOverlay: { flex: 1, backgroundColor: "rgba(0,0,0,0.4)", justifyContent: "center", alignItems: "center", padding: 20 },
  modalContent: { backgroundColor: "#fff", borderRadius: 16, padding: 20, width: "100%", maxWidth: 320 },
  modalTitle: { fontSize: 18, fontWeight: "bold", marginBottom: 15, textAlign: "center", fontFamily: FONT, color: "#4A2E10" },
  timeInputRow: { flexDirection: "row", justifyContent: "center", alignItems: "center", marginBottom: 20 },
  timeInput: { borderWidth: 1.5, borderColor: "#E0C090", borderRadius: 8, padding: 10, width: 60, textAlign: "center", fontSize: 20, fontWeight: "bold", color: "#4A2E10" },
  timeColon: { fontSize: 24, fontWeight: "bold", marginHorizontal: 10, color: "#7B5030" },
  btn: { padding: 12, borderRadius: 8, alignItems: "center", marginBottom: 8 },
  btnSave: { backgroundColor: "#4CAF50" },
  btnDelete: { backgroundColor: "#EF4444" },
  btnCancel: { backgroundColor: "#F5EDE3" },
  btnText: { color: "#fff", fontWeight: "bold", fontSize: 14, fontFamily: FONT }
});